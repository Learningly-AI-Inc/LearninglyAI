{
  "git": {
    "deploymentEnabled": false
  },
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "functions": {
    "app/api/exam-prep/upload/route.ts": {
      "maxDuration": 60
    },
    "app/api/reading/upload/route.ts": {
      "maxDuration": 60
    },
    "app/api/calendar/process-syllabus/route.ts": {
      "maxDuration": 60
    },
    "app/api/calendar/generate-schedule/route.ts": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/sync-stripe",
      "schedule": "0 */6 * * *"
    }
  ]
}
